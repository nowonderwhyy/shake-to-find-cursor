<Window x:Class="ShakeToFindCursor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shake to Find Cursor" 
        Height="550" Width="750"
        MinHeight="550" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C" Foreground="#EDEDED"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="AccentBrush" Color="#4EB3FF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1C1C1C"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#252525"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#333333"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EDEDED"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3D3D3D"/>
        
        <!-- Sidebar Category Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" 
                                           FontFamily="Segoe MDL2 Assets" 
                                           FontSize="16" 
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                <TextBlock x:Name="text" Text="{TemplateBinding Content}" 
                                           FontSize="14" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#353535"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="44" Height="24">
                                <Border x:Name="track" 
                                        Background="#505050"
                                        CornerRadius="12"
                                        Opacity="1"/>
                                <Border x:Name="thumb" 
                                        Width="20" Height="20"
                                        Background="White"
                                        CornerRadius="10"
                                        HorizontalAlignment="Left"
                                        Margin="2,0,0,0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="thumbTranslate" X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                            <ContentPresenter Margin="12,0,0,0" 
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="thumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="thumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumb" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#404040"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Accent Button Style -->
        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#1C1C1C"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6BC4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3AA3E8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Slider Style -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{StaticResource AccentBrush}" 
                                                        Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#505050" 
                                                        Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="18" Height="18" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbEllipse" 
                                                         Fill="White" 
                                                         Width="18" Height="18">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" 
                                                                          Opacity="0.3" Direction="270"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbEllipse" Property="Fill" Value="#F0F0F0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="thumbEllipse" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern ComboBox Style with proper dropdown styling -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#EDEDED"/>
            <Setter Property="BorderBrush" Value="#505050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#3A3A3A"/>
                        <Setter Property="Foreground" Value="#EDEDED"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" 
                                            Background="{TemplateBinding Background}" 
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4EB3FF"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3D6A99"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="{TemplateBinding Padding}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>
                                    <Path Grid.Column="1" 
                                          Data="M0,0 L4,4 L8,0" 
                                          Fill="#A0A0A0"
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Center"
                                          Stroke="#A0A0A0"
                                          StrokeThickness="1.5"/>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Background="#3A3A3A"
                                        BorderBrush="#505050"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="300">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#4EB3FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Card Style -->
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        
        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        
        <!-- Setting Label Style -->
        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- Setting Description Style -->
        <Style x:Key="SettingDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        
        <!-- ListBox Style for Excluded Apps -->
        <Style x:Key="ExcludedAppsListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.RowSpan="2" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- App Title -->
                <StackPanel Margin="16,20,16,20">
                    <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                
                <!-- Category Buttons -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <RadioButton x:Name="NavGeneral" Style="{StaticResource SidebarButtonStyle}"
                                 Content="General" Tag="&#xE713;" IsChecked="True"
                                 Checked="NavCategory_Checked"/>
                    <RadioButton x:Name="NavAnimation" Style="{StaticResource SidebarButtonStyle}"
                                 Content="Animation" Tag="&#xE916;"
                                 Checked="NavCategory_Checked"/>
                    <RadioButton x:Name="NavAppearance" Style="{StaticResource SidebarButtonStyle}"
                                 Content="Appearance" Tag="&#xE771;"
                                 Checked="NavCategory_Checked"/>
                    <RadioButton x:Name="NavCompatibility" Style="{StaticResource SidebarButtonStyle}"
                                 Content="Compatibility" Tag="&#xE74C;"
                                 Checked="NavCategory_Checked"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Content Area -->
        <Border Grid.Column="1" Grid.Row="0" Margin="0">
            <Grid x:Name="ContentArea">
                <!-- General Settings Panel -->
                <ScrollViewer x:Name="PanelGeneral" VerticalScrollBarVisibility="Auto" Padding="24">
                    <StackPanel>
                        <TextBlock Text="GENERAL" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <!-- Enable/Disable -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Enable Shake to Find" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Shake your mouse to highlight the cursor location" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox x:Name="ToggleEnabled" Grid.Column="1" 
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <!-- Run on Startup -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Run on Startup" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Automatically start when Windows boots" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox x:Name="ToggleStartup" Grid.Column="1" 
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <!-- Reset to Defaults -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Reset to Defaults" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Restore all settings to their original values" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <Button Content="Reset" Grid.Column="1" 
                                        Style="{StaticResource ModernButtonStyle}"
                                        Click="BtnReset_Click"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <TextBlock Text="DETECTION" Style="{StaticResource SectionHeaderStyle}" Margin="0,12,0,12"/>
                        
                        <!-- Shake Sensitivity -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Shake Sensitivity" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelThreshold" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="SliderThreshold" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="500" Maximum="4000" TickFrequency="100"
                                        Margin="0,12,0,0"
                                        ValueChanged="SliderThreshold_ValueChanged"/>
                                <TextBlock Text="Lower values require more vigorous shaking" 
                                           Style="{StaticResource SettingDescriptionStyle}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Time Window -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Detection Window" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelTimeWindow" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="SliderTimeWindow" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="100" Maximum="1000" TickFrequency="50"
                                        Margin="0,12,0,0"
                                        ValueChanged="SliderTimeWindow_ValueChanged"/>
                                <TextBlock Text="Time period in which shaking must occur" 
                                           Style="{StaticResource SettingDescriptionStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Animation Settings Panel -->
                <ScrollViewer x:Name="PanelAnimation" VerticalScrollBarVisibility="Auto" 
                              Padding="24" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="PRESET" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <!-- Animation Preset -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Animation Style" Style="{StaticResource SettingLabelStyle}"/>
                                <ComboBox x:Name="ComboPreset" 
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,8,0,0"
                                          SelectionChanged="ComboPreset_SelectionChanged">
                                    <ComboBoxItem Content="macOS Classic"/>
                                    <ComboBoxItem Content="Subtle"/>
                                    <ComboBoxItem Content="Dramatic"/>
                                    <ComboBoxItem Content="Snappy"/>
                                    <ComboBoxItem Content="Smooth"/>
                                    <ComboBoxItem Content="Custom"/>
                                </ComboBox>
                                <TextBlock Text="Choose a preset or customize your own animation" 
                                           Style="{StaticResource SettingDescriptionStyle}"/>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="CUSTOM PARAMETERS" Style="{StaticResource SectionHeaderStyle}" Margin="0,12,0,12"/>
                        
                        <!-- Size When Shaken -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Size when shaken" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelMagnification" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="SliderMagnification" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="2" Maximum="12" TickFrequency="0.5"
                                        Margin="0,12,0,0"
                                        ValueChanged="SliderMagnification_ValueChanged"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Hold Duration -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Hold duration" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelHoldDuration" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="SliderHoldDuration" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="80" Maximum="600" TickFrequency="20"
                                        Margin="0,12,0,0"
                                        ValueChanged="SliderHoldDuration_ValueChanged"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Expand Speed -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Expand speed" Style="{StaticResource SettingLabelStyle}"/>
                                <ComboBox x:Name="ComboExpandSpeed" 
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,8,0,0"
                                          SelectionChanged="ComboExpandSpeed_SelectionChanged">
                                    <ComboBoxItem Content="Low"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="High"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                        
                        <!-- Shrink Speed -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Shrink speed" Style="{StaticResource SettingLabelStyle}"/>
                                <ComboBox x:Name="ComboShrinkSpeed" 
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,8,0,0"
                                          SelectionChanged="ComboShrinkSpeed_SelectionChanged">
                                    <ComboBoxItem Content="Low"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="High"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                        
                        <!-- Bounce Amount -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Bounce amount" Style="{StaticResource SettingLabelStyle}"/>
                                <ComboBox x:Name="ComboBounce" 
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,8,0,0"
                                          SelectionChanged="ComboBounce_SelectionChanged">
                                    <ComboBoxItem Content="None"/>
                                    <ComboBoxItem Content="Subtle"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="Bouncy"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                        
                        <!-- Test Animation -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Test Animation" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Preview the current animation settings" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <Button x:Name="BtnTest" Content="Test" Grid.Column="1" 
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="BtnTest_Click"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Appearance Settings Panel -->
                <ScrollViewer x:Name="PanelAppearance" VerticalScrollBarVisibility="Auto" 
                              Padding="24" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="RENDERER" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <!-- Renderer Selection -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Rendering Method" Style="{StaticResource SettingLabelStyle}"/>
                                <ComboBox x:Name="ComboRenderer" 
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,8,0,0"
                                          SelectionChanged="ComboRenderer_SelectionChanged">
                                    <ComboBoxItem Content="Overlay (Recommended)"/>
                                    <ComboBoxItem Content="Cursor Replacement (Legacy)"/>
                                </ComboBox>
                                <TextBlock Text="Overlay draws a ring around the cursor. Legacy replaces the cursor image." 
                                           Style="{StaticResource SettingDescriptionStyle}"/>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="RING APPEARANCE" Style="{StaticResource SectionHeaderStyle}" Margin="0,12,0,12"/>
                        
                        <!-- Ring Color -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Ring Color" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Color of the highlight ring" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <Button x:Name="BtnColorPicker" Grid.Column="1"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Click="BtnColorPicker_Click"
                                        VerticalAlignment="Center"
                                        Padding="0" Width="44" Height="32">
                                    <Border x:Name="ColorPreview" 
                                            Width="36" Height="24" 
                                            CornerRadius="4"
                                            Background="#808080"/>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <!-- Ring Opacity -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Ring Opacity" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelRingOpacity" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="SliderRingOpacity" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0.1" Maximum="1.0" TickFrequency="0.05"
                                        Margin="0,12,0,0"
                                        ValueChanged="SliderRingOpacity_ValueChanged"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Ring Thickness -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Ring Thickness" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelRingThickness" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="SliderRingThickness" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="1" Maximum="10" TickFrequency="0.5"
                                        Margin="0,12,0,0"
                                        ValueChanged="SliderRingThickness_ValueChanged"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Show Spotlight -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Show Spotlight Effect" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Add a soft glow behind the cursor" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox x:Name="ToggleSpotlight" Grid.Column="1" 
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Compatibility Settings Panel -->
                <ScrollViewer x:Name="PanelCompatibility" VerticalScrollBarVisibility="Auto" 
                              Padding="24" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="FULLSCREEN" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <!-- Disable in Fullscreen -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Disable in Fullscreen Apps" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Automatically disable when games or videos are fullscreen" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox x:Name="ToggleFullscreen" Grid.Column="1" 
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <TextBlock Text="EXCLUDED APPLICATIONS" Style="{StaticResource SectionHeaderStyle}" Margin="0,12,0,12"/>
                        
                        <!-- Excluded Apps List -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Never activate in these applications:" 
                                           Style="{StaticResource SettingLabelStyle}" Margin="0,0,0,8"/>
                                
                                <ListBox x:Name="ListExcludedApps" 
                                         Style="{StaticResource ExcludedAppsListStyle}"
                                         Height="150"
                                         SelectionMode="Single"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="BtnAddCurrentApp" Content="+ Foreground App" 
                                            Style="{StaticResource ModernButtonStyle}"
                                            Click="BtnAddCurrentApp_Click"
                                            Margin="0,0,8,0"/>
                                    <Button x:Name="BtnAddApp" Content="Browse Apps..." 
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="BtnAddApp_Click"
                                            Margin="0,0,8,0"/>
                                    <Button x:Name="BtnRemoveApp" Content="Remove" 
                                            Style="{StaticResource ModernButtonStyle}"
                                            Click="BtnRemoveApp_Click"/>
                                </StackPanel>
                                
                                <TextBlock Text="Click 'Browse Apps...' to select from running applications" 
                                           Style="{StaticResource SettingDescriptionStyle}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <!-- Bottom Bar -->
        <Border Grid.Column="1" Grid.Row="1" 
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Auto-save indicator -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SaveIndicator" 
                               Text="● Settings saved" 
                               Foreground="#6BC4FF" 
                               FontSize="12"
                               Opacity="0"/>
                </StackPanel>
                
                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnApply" Content="Apply" 
                            Style="{StaticResource AccentButtonStyle}"
                            Click="BtnApply_Click"
                            Width="90" Margin="0,0,8,0"/>
                    <Button x:Name="BtnClose" Content="Close" 
                            Style="{StaticResource ModernButtonStyle}"
                            Click="BtnClose_Click"
                            Width="90"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
