<Window x:Class="ShakeToFindCursor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shake to Find Cursor - Settings" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C" Foreground="#EDEDED"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,5" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,0,10,15" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="C U R S O R   P R E F E R E N C E S" FontSize="18" FontWeight="SemiBold" Foreground="#4EB3FF" Margin="0,0,0,20"/>

        <TextBlock Text="Size when shaken:" Grid.Row="1"/>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderMagnification" Minimum="2" Maximum="12" TickFrequency="0.5" ValueChanged="SliderMagnification_ValueChanged"/>
            <TextBlock x:Name="TxtMagnificationValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Text="6.0x" />
        </Grid>

        <TextBlock Text="Stay enlarged for:" Grid.Row="3"/>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderHold" Minimum="80" Maximum="600" TickFrequency="20" ValueChanged="SliderHold_ValueChanged"/>
            <TextBlock x:Name="TxtHoldValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Text="240 ms" />
        </Grid>

        <CheckBox x:Name="CheckStartup" Grid.Row="5" Content="Start automatically with Windows" Margin="0,15,0,20" FontSize="14" Foreground="#EDEDED"/>

        <Expander Header="Advanced detection" Grid.Row="6" Margin="0,12,0,12" Foreground="#EDEDED" FontSize="14">
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="Shake sensitivity threshold" />
                <Slider x:Name="SliderThreshold" Minimum="500" Maximum="4000" TickFrequency="100" />
                <TextBlock Text="Shake time window" />
                <Slider x:Name="SliderTime" Minimum="100" Maximum="1000" TickFrequency="50" />
            </StackPanel>
        </Expander>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnTest" Content="Test" Height="30" Width="80" Margin="0,0,10,0" Click="BtnTest_Click" Background="#2B2B2B" Foreground="White" BorderBrush="#3D3D3D" FontSize="13"/>
            <Button x:Name="BtnApply" Content="Apply" Height="30" Width="80" Margin="0,0,10,0" Click="BtnApply_Click" Background="#4EB3FF" Foreground="Black" BorderBrush="#4EB3FF" FontSize="13" FontWeight="SemiBold"/>
            <Button x:Name="BtnClose" Content="Close" Height="30" Width="80" Click="BtnClose_Click" Background="#2B2B2B" Foreground="White" BorderBrush="#3D3D3D" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>
