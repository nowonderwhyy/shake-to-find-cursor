<Window x:Class="ShakeToFindCursor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shake to Find Cursor" 
        Height="580" Width="700"
        MinHeight="550" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="#E5E5E5"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="AccentBrush" Color="#0A84FF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#409CFF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#252525"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#363636"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8E8E93"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3C"/>
        <SolidColorBrush x:Key="ControlBgBrush" Color="#3A3A3C"/>
        
        <!-- Sidebar Category Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" 
                                           FontFamily="Segoe MDL2 Assets" 
                                           FontSize="15" 
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <TextBlock x:Name="text" Text="{TemplateBinding Content}" 
                                           FontSize="13" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#323232"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3C"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="44" Height="26">
                            <Border x:Name="track" 
                                    Background="#636366"
                                    CornerRadius="13"/>
                            <Border x:Name="thumb" 
                                    Width="22" Height="22"
                                    Background="White"
                                    CornerRadius="11"
                                    HorizontalAlignment="Left"
                                    Margin="2,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.3" Direction="270"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="thumbTranslate" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="thumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="18" Duration="0:0:0.12">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="thumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.12">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ControlBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#484848"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#404040"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Accent Button Style -->
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0070E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Slider Style -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{StaticResource AccentBrush}" 
                                                        Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#48484A" 
                                                        Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="20" Height="20" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbEllipse" 
                                                         Fill="White" 
                                                         Width="20" Height="20">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" 
                                                                          Opacity="0.35" Direction="270"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbEllipse" Property="Fill" Value="#F5F5F5"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="thumbEllipse" Property="Fill" Value="#E8E8E8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource ControlBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" 
                                            Background="{TemplateBinding Background}" 
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4"
                                            Margin="4,2">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#48484A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="{TemplateBinding Padding}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>
                                    <Path Grid.Column="1" 
                                          Data="M0,0 L5,5 L10,0" 
                                          Fill="{StaticResource TextSecondaryBrush}"
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Center"
                                          StrokeThickness="0"/>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  ClickMode="Press"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#2D2D2D"
                                        BorderBrush="#48484A"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,4,0,0"
                                        Padding="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="280">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.3" Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#48484A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Card Style -->
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <!-- Setting Label Style -->
        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- Setting Description Style -->
        <Style x:Key="SettingDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
        
        <!-- ListBox Style for Excluded Apps -->
        <Style x:Key="ExcludedAppsListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer>
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#363636"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.RowSpan="2" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- App Title -->
                <StackPanel Margin="16,18,16,16">
                    <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                
                <!-- Category Buttons -->
                <StackPanel Grid.Row="1" Margin="0,4,0,0">
                    <RadioButton x:Name="NavGeneral" Style="{StaticResource SidebarButtonStyle}"
                                 Content="General" Tag="&#xE713;" IsChecked="True"
                                 Checked="NavCategory_Checked"/>
                    <RadioButton x:Name="NavAnimation" Style="{StaticResource SidebarButtonStyle}"
                                 Content="Animation" Tag="&#xE916;"
                                 Checked="NavCategory_Checked"/>
                    <RadioButton x:Name="NavCompatibility" Style="{StaticResource SidebarButtonStyle}"
                                 Content="Compatibility" Tag="&#xE74C;"
                                 Checked="NavCategory_Checked"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Content Area -->
        <Border Grid.Column="1" Grid.Row="0">
            <Grid x:Name="ContentArea">
                <!-- General Settings Panel -->
                <ScrollViewer x:Name="PanelGeneral" VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel MaxWidth="500">
                        <TextBlock Text="GENERAL" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <!-- Run on Startup -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Launch at Login" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Automatically start when Windows boots" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox x:Name="ToggleStartup" Grid.Column="1" 
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <TextBlock Text="SHAKE DETECTION" Style="{StaticResource SectionHeaderStyle}" Margin="0,8,0,10"/>
                        
                        <!-- Shake Sensitivity -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sensitivity" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelThreshold" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"/>
                                </Grid>
                                <Slider x:Name="SliderThreshold" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="500" Maximum="4000" TickFrequency="100"
                                        Margin="0,10,0,0"
                                        ValueChanged="SliderThreshold_ValueChanged"/>
                                <TextBlock Text="Lower values require more vigorous shaking" 
                                           Style="{StaticResource SettingDescriptionStyle}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Time Window -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Detection Window" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelTimeWindow" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"/>
                                </Grid>
                                <Slider x:Name="SliderTimeWindow" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="100" Maximum="1000" TickFrequency="50"
                                        Margin="0,10,0,0"
                                        ValueChanged="SliderTimeWindow_ValueChanged"/>
                                <TextBlock Text="Time period in which shaking must occur" 
                                           Style="{StaticResource SettingDescriptionStyle}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Reset to Defaults -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Reset All Settings" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Restore everything to factory defaults" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <Button Content="Reset" Grid.Column="1" 
                                        Style="{StaticResource ModernButtonStyle}"
                                        Click="BtnReset_Click"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Animation Settings Panel -->
                <ScrollViewer x:Name="PanelAnimation" VerticalScrollBarVisibility="Auto" 
                              Padding="20" Visibility="Collapsed">
                    <StackPanel MaxWidth="500">
                        <TextBlock Text="PRESET" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <!-- Animation Preset -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Animation Style" Style="{StaticResource SettingLabelStyle}"/>
                                <ComboBox x:Name="ComboPreset" 
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,8,0,0"
                                          SelectionChanged="ComboPreset_SelectionChanged">
                                    <ComboBoxItem Content="macOS Classic"/>
                                    <ComboBoxItem Content="Subtle"/>
                                    <ComboBoxItem Content="Dramatic"/>
                                    <ComboBoxItem Content="Snappy"/>
                                    <ComboBoxItem Content="Smooth"/>
                                    <ComboBoxItem Content="Custom"/>
                                </ComboBox>
                                <TextBlock Text="Choose a preset or customize your own" 
                                           Style="{StaticResource SettingDescriptionStyle}"/>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="FINE TUNING" Style="{StaticResource SectionHeaderStyle}" Margin="0,8,0,10"/>
                        
                        <!-- Size -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Cursor Size" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelMagnification" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"/>
                                </Grid>
                                <Slider x:Name="SliderMagnification" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="2" Maximum="10" TickFrequency="0.5"
                                        Margin="0,10,0,0"
                                        ValueChanged="SliderMagnification_ValueChanged"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Hold Duration -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Hold Duration" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock x:Name="LabelHoldDuration" Grid.Column="1" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"/>
                                </Grid>
                                <Slider x:Name="SliderHoldDuration" 
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="80" Maximum="500" TickFrequency="20"
                                        Margin="0,10,0,0"
                                        ValueChanged="SliderHoldDuration_ValueChanged"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Expand Speed -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Expand Speed" Style="{StaticResource SettingLabelStyle}"/>
                                <ComboBox x:Name="ComboExpandSpeed" Grid.Column="1"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="ComboExpandSpeed_SelectionChanged">
                                    <ComboBoxItem Content="Slow"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="Fast"/>
                                </ComboBox>
                            </Grid>
                        </Border>
                        
                        <!-- Shrink Speed -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Shrink Speed" Style="{StaticResource SettingLabelStyle}"/>
                                <ComboBox x:Name="ComboShrinkSpeed" Grid.Column="1"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="ComboShrinkSpeed_SelectionChanged">
                                    <ComboBoxItem Content="Slow"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="Fast"/>
                                </ComboBox>
                            </Grid>
                        </Border>
                        
                        <!-- Bounce -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bounce Amount" Style="{StaticResource SettingLabelStyle}"/>
                                <ComboBox x:Name="ComboBounce" Grid.Column="1"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="ComboBounce_SelectionChanged">
                                    <ComboBoxItem Content="None"/>
                                    <ComboBoxItem Content="Subtle"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="Bouncy"/>
                                </ComboBox>
                            </Grid>
                        </Border>
                        
                        <!-- Test Button -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Preview Animation" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Test the current animation settings" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <Button x:Name="BtnTest" Content="Test" Grid.Column="1" 
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="BtnTest_Click"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Compatibility Settings Panel -->
                <ScrollViewer x:Name="PanelCompatibility" VerticalScrollBarVisibility="Auto" 
                              Padding="20" Visibility="Collapsed">
                    <StackPanel MaxWidth="500">
                        <TextBlock Text="AUTOMATIC DISABLE" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <!-- Disable in Fullscreen -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Disable in Fullscreen" Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Pause when games or videos are fullscreen" 
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox x:Name="ToggleFullscreen" Grid.Column="1" 
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <TextBlock Text="EXCLUDED APPS" Style="{StaticResource SectionHeaderStyle}" Margin="0,8,0,10"/>
                        
                        <!-- Excluded Apps List -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Never activate in these applications:" 
                                           Style="{StaticResource SettingLabelStyle}" Margin="0,0,0,8"/>
                                
                                <ListBox x:Name="ListExcludedApps" 
                                         Style="{StaticResource ExcludedAppsListStyle}"
                                         Height="140"
                                         SelectionMode="Single"/>
                                
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="BtnAddApp" Content="Add App..." 
                                                Style="{StaticResource AccentButtonStyle}"
                                                Click="BtnAddApp_Click"
                                                Margin="0,0,8,0"/>
                                        <Button x:Name="BtnAddCurrentApp" Content="+ Current" 
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="BtnAddCurrentApp_Click"
                                                ToolTip="Add the currently focused application"/>
                                    </StackPanel>
                                    <Button x:Name="BtnRemoveApp" Content="Remove" Grid.Column="1"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Click="BtnRemoveApp_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <!-- Bottom Bar -->
        <Border Grid.Column="1" Grid.Row="1" 
                Background="{StaticResource SidebarBrush}"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Save indicator -->
                <TextBlock x:Name="SaveIndicator" 
                           Text="✓ Saved" 
                           Foreground="{StaticResource AccentBrush}" 
                           FontSize="12"
                           VerticalAlignment="Center"
                           Opacity="0"/>
                
                <!-- Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnApply" Content="Apply" 
                            Style="{StaticResource AccentButtonStyle}"
                            Click="BtnApply_Click"
                            Width="85" Margin="0,0,8,0"/>
                    <Button x:Name="BtnClose" Content="Done" 
                            Style="{StaticResource ModernButtonStyle}"
                            Click="BtnClose_Click"
                            Width="85"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
